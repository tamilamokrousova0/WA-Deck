{
  "name": "wa-deck",
  "version": "0.6.4",
  "description": "WA Deck: multi-account WhatsApp manager",
  "main": "src/main.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "start": "electron .",
    "dev": "electron .",
    "dist:mac": "electron-builder --mac dmg zip --arm64",
    "dist:win": "electron-builder --win nsis --x64",
    "dist:all": "npm run dist:mac && npm run dist:win",
    "dist": "npm run dist:mac && npm run dist:win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "electron-updater": "^6.3.9"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.local.wadeck",
    "productName": "WA Deck",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.social-networking",
      "icon": "assets/icon/icon.icns",
      "artifactName": "WA-Deck-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "icon": "assets/icon/icon.ico",
      "artifactName": "WA-Deck-Setup-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "assets/icon/icon.ico",
      "uninstallerIcon": "assets/icon/icon.ico"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "tamilamokrousova0",
        "repo": "WA-Deck",
        "releaseType": "release"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tamilamokrousova0/WA-Deck.git"
  },
  "homepage": "https://github.com/tamilamokrousova0/WA-Deck",
  "bugs": {
    "url": "https://github.com/tamilamokrousova0/WA-Deck/issues"
  }
}
